# ---------------------------------------------------------------------------
# Byte-compiled / cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
.coverage
htmlcov/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/

# ---------------------------------------------------------------------------
# Data — never commit large datasets (regenerate via the download helper or
# the synthetic fallback)
# ---------------------------------------------------------------------------
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
data/raw/*.csv
data/processed/*.csv
reports/*.csv

# ---------------------------------------------------------------------------
# Models & artifacts (regenerated by `python main.py`)
# ---------------------------------------------------------------------------
models/*.joblib
models/*.json
!models/.gitkeep

# ---------------------------------------------------------------------------
# Reports (regenerated each run)
# ---------------------------------------------------------------------------
reports/*.png
reports/*.csv
reports/*.json
reports/*.txt
reports/shap/
reports/optuna/
!reports/.gitkeep

# ---------------------------------------------------------------------------
# Logs & experiment tracking
# ---------------------------------------------------------------------------
logs/*.log
!logs/.gitkeep
mlruns/
mlartifacts/

# ---------------------------------------------------------------------------
# Misc / tooling
# ---------------------------------------------------------------------------
pip_install.log

# OS / editor
.DS_Store
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/


# ---------------------------------------------------------------------------
# Git
# ---------------------------------------------------------------------------
.git/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
*.pyd
*.pyo

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
.env
.env.*
.python-version

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------
build/
dist/

# ---------------------------------------------------------------------------
# Packaging
# ---------------------------------------------------------------------------
*.whl

# ---------------------------------------------------------------------------
# macOS / Windows
# ---------------------------------------------------------------------------
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Temporary
# ---------------------------------------------------------------------------
*.tmp
*.temp

# ---------------------------------------------------------------------------
# VS Code Workspace
# ---------------------------------------------------------------------------
*.code-workspace
# Docker
.docker/